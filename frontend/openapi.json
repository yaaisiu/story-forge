{
  "openapi": "3.1.0",
  "info": {
    "title": "Story Forge",
    "description": "Agent-orchestrated narrative analysis with a Neo4j knowledge graph.",
    "version": "0.0.0"
  },
  "paths": {
    "/stories/upload": {
      "post": {
        "tags": [
          "stories"
        ],
        "summary": "Upload Story",
        "operationId": "upload_story_stories_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_story_stories_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoryUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Uploaded file is empty or unparseable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "File exceeds the maximum upload size.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "415": {
            "description": "Unsupported file extension or content type mismatch.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stories/{story_id}/structure": {
      "post": {
        "tags": [
          "stories"
        ],
        "summary": "Structure Story",
        "description": "Build the document tree for a story (spec \u00a77 step 2) and persist it.\n\nReads the story's stored raw text \u2014 which already carries the author's\n`##` / `###` anchors for manual/hybrid \u2014 builds the outline in the chosen\nmode, and inserts chapters \u2192 scenes \u2192 paragraphs. One-shot: the accept/edit\nloop is the frontend's job (Session 6). Re-structuring is refused (409) rather\nthan silently appending a second tree.\n\nLocking strategy: the outline is built *without* holding a DB write lock,\nbecause auto/hybrid awaits an LLM call that can take seconds. The story row\nis then `SELECT ... FOR UPDATE`-locked only for the small write window \u2014\nre-check `list_chapters` under the lock, then insert. Two concurrent POSTs\nserialize on the lock: the second sees the persisted tree and 409s instead\nof duplicating.",
        "operationId": "structure_story_stories__story_id__structure_post",
        "parameters": [
          {
            "name": "story_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Story Id"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": true,
            "schema": {
              "enum": [
                "auto",
                "manual",
                "hybrid"
              ],
              "type": "string",
              "title": "Mode"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/StructureRequestBody"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Body"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StructureResponse"
                }
              }
            }
          },
          "404": {
            "description": "Story not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Story already has a structure (re-structure is refused).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Chunking agent failed \u2014 LLM unreachable or unusable output after retries.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stories/{story_id}/extract": {
      "post": {
        "tags": [
          "stories"
        ],
        "summary": "Extract Story",
        "description": "Extract entities/relations from a story's paragraphs into the graph (spec \u00a79 M2).\n\nWalks every persisted paragraph, runs the ExtractionAgent, and writes fresh graph\nnodes/edges + `entity_mentions` with **no dedupe** (INV-8 \u2014 every candidate a new\nnode). The batch is resumable: if the router pauses on budget/quota, the run stops\nwith `paused=true` (HTTP 202) and a re-POST continues from the last-done paragraph\n(the committed mentions are the checkpoint). Budget/quota are therefore *not* HTTP\nerrors here by design (OQ-2); only a hard agent failure maps to 502.",
        "operationId": "extract_story_stories__story_id__extract_post",
        "parameters": [
          {
            "name": "story_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Story Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractResponse"
                }
              }
            }
          },
          "202": {
            "description": "Budget/quota pause hit mid-batch; partial progress, re-POST to resume.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractResponse"
                }
              }
            }
          },
          "404": {
            "description": "Story not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Extraction failed \u2014 LLM unreachable or unusable output after retries.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/llm/status": {
      "get": {
        "tags": [
          "llm"
        ],
        "summary": "Llm Status",
        "description": "Today's spend, GPU-seconds, and per-task-type breakdown against the cap.",
        "operationId": "llm_status_llm_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LlmStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Liveness probe used by the frontend smoke check and by CI.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_upload_story_stories_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_story_stories_upload_post"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse",
        "description": "Shape FastAPI's ``HTTPException`` produces \u2014 declared so the OpenAPI\nschema names every non-2xx response the routes can return, instead of just\nsuccess + the auto-added 422 validation error. Without this, the generated\nTypeScript client (`frontend/src/lib/api/schema.d.ts`) can't model expected\noutcomes like 404 / 409 / 502 \u2014 leaving frontend error handling untyped."
      },
      "ExtractResponse": {
        "properties": {
          "story_id": {
            "type": "string",
            "format": "uuid",
            "title": "Story Id"
          },
          "paragraphs_total": {
            "type": "integer",
            "title": "Paragraphs Total"
          },
          "paragraphs_done": {
            "type": "integer",
            "title": "Paragraphs Done"
          },
          "entities_written": {
            "type": "integer",
            "title": "Entities Written"
          },
          "relations_written": {
            "type": "integer",
            "title": "Relations Written"
          },
          "paused": {
            "type": "boolean",
            "title": "Paused"
          },
          "pause_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pause Reason"
          }
        },
        "type": "object",
        "required": [
          "story_id",
          "paragraphs_total",
          "paragraphs_done",
          "entities_written",
          "relations_written",
          "paused",
          "pause_reason"
        ],
        "title": "ExtractResponse",
        "description": "Progress of an extraction run over a story's paragraphs (spec \u00a79 M2).\n\n`paused` is the completion signal \u2014 true when the run stopped at the budget/quota\npause-and-ask (HTTP 202, partial progress), false when it finished (HTTP 200).\n`paragraphs_done` counts paragraphs that carry a mention \u2014 the resumable\ncheckpoint \u2014 so a re-POST resumes from the first not-done paragraph."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LlmStatusResponse": {
        "properties": {
          "daily_budget_usd": {
            "type": "number",
            "title": "Daily Budget Usd"
          },
          "spent_today_usd": {
            "type": "number",
            "title": "Spent Today Usd"
          },
          "remaining_usd": {
            "type": "number",
            "title": "Remaining Usd"
          },
          "gpu_seconds_today": {
            "type": "number",
            "title": "Gpu Seconds Today"
          },
          "calls_today": {
            "type": "integer",
            "title": "Calls Today"
          },
          "by_task_type": {
            "items": {
              "$ref": "#/components/schemas/TaskTypeUsage"
            },
            "type": "array",
            "title": "By Task Type"
          }
        },
        "type": "object",
        "required": [
          "daily_budget_usd",
          "spent_today_usd",
          "remaining_usd",
          "gpu_seconds_today",
          "calls_today",
          "by_task_type"
        ],
        "title": "LlmStatusResponse",
        "description": "Budget + today's usage for the agent-activity panel."
      },
      "StoryUploadResponse": {
        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid",
            "title": "Project Id"
          },
          "story_id": {
            "type": "string",
            "format": "uuid",
            "title": "Story Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "language": {
            "type": "string",
            "title": "Language"
          },
          "paragraph_count": {
            "type": "integer",
            "title": "Paragraph Count"
          },
          "raw_text": {
            "type": "string",
            "title": "Raw Text"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "story_id",
          "title",
          "language",
          "paragraph_count",
          "raw_text"
        ],
        "title": "StoryUploadResponse",
        "description": "What the upload route returns once a story is persisted.\n\n``raw_text`` is echoed back so the frontend's manual-mode editor (spec \u00a77\nstep 2) has the parsed source to edit. The browser doesn't reliably parse\n.docx itself, so the upload response is the cheapest place to surface it;\navoids a follow-up GET /stories/{id} round-trip that doesn't exist yet."
      },
      "StructureRequestBody": {
        "properties": {
          "raw_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Text"
          }
        },
        "type": "object",
        "title": "StructureRequestBody",
        "description": "Optional body for ``POST /stories/{id}/structure``.\n\nWhen ``raw_text`` is provided, the route parses the outline from this payload\ninstead of the story's stored copy AND persists it back to ``stories.raw_text``\nin the same transaction. This is how the frontend manual-mode editor\n(spec \u00a77 step 2 \"user accepts/edits\") commits its source-marker edits without\na separate PATCH route. When ``raw_text`` is omitted or null, the route reads\nthe stored copy and does not modify it \u2014 backwards-compatible."
      },
      "StructureResponse": {
        "properties": {
          "story_id": {
            "type": "string",
            "format": "uuid",
            "title": "Story Id"
          },
          "mode": {
            "type": "string",
            "enum": [
              "auto",
              "manual",
              "hybrid"
            ],
            "title": "Mode"
          },
          "chapter_count": {
            "type": "integer",
            "title": "Chapter Count"
          },
          "scene_count": {
            "type": "integer",
            "title": "Scene Count"
          },
          "paragraph_count": {
            "type": "integer",
            "title": "Paragraph Count"
          }
        },
        "type": "object",
        "required": [
          "story_id",
          "mode",
          "chapter_count",
          "scene_count",
          "paragraph_count"
        ],
        "title": "StructureResponse",
        "description": "What the structure route returns once the outline is persisted."
      },
      "TaskTypeUsage": {
        "properties": {
          "task_type": {
            "type": "string",
            "title": "Task Type"
          },
          "calls": {
            "type": "integer",
            "title": "Calls"
          },
          "cost_usd": {
            "type": "number",
            "title": "Cost Usd"
          }
        },
        "type": "object",
        "required": [
          "task_type",
          "calls",
          "cost_usd"
        ],
        "title": "TaskTypeUsage",
        "description": "Today's call count and USD spend for one task type (status dashboard)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}

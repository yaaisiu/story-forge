{
  "name": "story-forge-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Story Forge frontend — React + Vite + TypeScript, React Router + TanStack Query + Tailwind shell. Typed API client generated from the backend's OpenAPI schema.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:api": "npx -y openapi-typescript@7.13.0 openapi.json -o src/lib/api/schema.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.10",
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-document": "3.26.0",
    "@tiptap/extension-paragraph": "3.26.0",
    "@tiptap/extension-text": "3.26.0",
    "@tiptap/pm": "3.26.0",
    "@tiptap/react": "3.26.0",
    "cytoscape": "3.33.4",
    "cytoscape-fcose": "2.2.0",
    "react": "19.0.5",
    "react-dom": "19.0.5",
    "react-router-dom": "7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.16",
    "vitest": "4.1.6"
  }
}

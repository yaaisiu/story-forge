# Story Forge — backend application environment.
#
# Copy to backend/.env and fill in real values:
#   cp backend/.env.example backend/.env
#
# Generate random secrets:
#   openssl rand -hex 24
#
# `backend/.env` is gitignored. NEVER commit it.
#
# These are the variables the backend (`story_forge.config.settings`) reads.
# They are intentionally separate from the repo-root `.env` so the backend
# never sees infra-tier secrets like the Postgres root password or the
# Neo4j AUTH triplet in the format the official images consume. The values
# below must be consistent with the repo-root `.env` (same Postgres user/
# password, same Neo4j password).

# --- Postgres connection (assembled URL the backend will use) ---
# The password segment MUST be identical to POSTGRES_PASSWORD in the repo-root
# .env — same user (storyforge), same database (storyforge). Copy that value
# in; only the password part below is a placeholder. Host is 127.0.0.1 because
# the backend runs bare-metal during M0 while compose binds 5432 to 127.0.0.1.
DATABASE_URL=postgresql+psycopg://storyforge:USE_ROOT_POSTGRES_PASSWORD@127.0.0.1:5432/storyforge

# Integration-test database. Same server/user/password as DATABASE_URL above,
# but a DISTINCT database name (story_forge_test). The pytest session fixture
# CREATEs this DB, runs `alembic upgrade head`, then DROPs it — so it must not
# be a database holding data you care about. Only the password is a placeholder.
TEST_DATABASE_URL=postgresql+psycopg://storyforge:USE_ROOT_POSTGRES_PASSWORD@127.0.0.1:5432/story_forge_test

# --- Neo4j connection ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-me-matches-NEO4J_AUTH-password-half

# --- Local LLM (Ollama on dev machine) ---
OLLAMA_HOST=http://127.0.0.1:11434

# --- Cloud LLM API keys (see ADR 0001 for the three-tier strategy) ---
# Ollama Cloud endpoint — the default chunking tier on a GPU-less host (spec §6.5).
# Optional override; the default below is what `OllamaProvider` uses when unset.
OLLAMA_CLOUD_HOST=https://ollama.com
# Required for the Ollama Cloud free-tier smoke test in CI AND for real
# chunking calls (auto/hybrid modes) — leave blank locally if you only run
# the unit/integration suite, which mocks the provider.
OLLAMA_CLOUD_API_KEY=

# --- Chunking agent (ingest step 2, spec §7) ---
# The model the ChunkingAgent calls. Defaults to the smaller `:20b-cloud` (Low
# Usage tier on Ollama Cloud) — chunking is a structural JSON task, not deep PL
# prose, so the 6× smaller variant of the gpt-oss family is sufficient. Bump to
# `gpt-oss:120b-cloud` (Medium Usage) if proposal quality is short on real text,
# or swap for a local tag (e.g. `qwen3.5:9b`) when a GPU host is set up.
CHUNKING_MODEL=gpt-oss:20b-cloud
# Word ceiling below which a configured local_small tier may be picked; on a
# GPU-less host this is moot (cloud_free runs regardless). Tune if needed.
CHUNKING_LOCAL_MAX_WORDS=4000

# --- Extraction agent (ingest step 4, spec §7/§9 M2) ---
# The model the ExtractionAgent calls (medium weight → cloud_free per §6.5). The
# larger `:120b-cloud` over chunking's 20b: pulling typed entities + relations from
# prose is a richer reasoning task than finding heading boundaries. Swap for a
# Qwen3.5 cloud variant if Polish recall is short on real long-form text.
EXTRACTION_MODEL=gpt-oss:120b-cloud

# Optional — fill any you actually use. Adapters are wired in M2.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# --- LLM budget (spec §6.6, ADR 0003) ---
# Per-day USD hard ceiling on paid spend. Fail-closed: the router checks it
# before dispatching a paid call and pauses to ask you when reached — it never
# silently escalates to more spend or kills work. Free tiers (Ollama local /
# cloud) are never blocked by this. Raise it deliberately for more headroom.
DAILY_BUDGET_USD=5.00

# --- Uploads ---
# Sandbox directory for original uploaded files (spec §6.7), resolved relative
# to the backend working directory. Optional — the default below is used if
# unset. Gitignored (backend/var/).
UPLOAD_DIR=var/uploads

# --- Backend ---
LOG_LEVEL=INFO
# Comma-separated list. CORS is strict (see spec §6.7). Both localhost and
# 127.0.0.1 forms for each dev port — Vite binds to 127.0.0.1 by default and
# the browser's Origin header reflects whatever the URL bar said.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Edit(.env)",
      "Edit(**/.env)",
      "Write(.env)",
      "Write(**/.env)"
    ]
  },
  "extraKnownMarketplaces": {
    "meta-architect-local": {
      "source": {
        "source": "directory",
        "path": "./meta-architect"
      }
    }
  },
  "enabledPlugins": {
    "meta-architect@meta-architect-local": true
  }
}

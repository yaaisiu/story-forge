# Story Forge — infrastructure / docker-compose environment.
#
# Copy to `.env` and fill in real values:
#   cp .env.example .env
#
# Generate random passwords:
#   openssl rand -hex 24
#
# `.env` is gitignored. NEVER commit it. The split between this file (infra
# credentials) and `backend/.env.example` (app credentials) is intentional —
# the backend should never see the raw Postgres root password or Neo4j auth
# in the format the official images consume. See spec §6.7 + ADR notes.

# --- Postgres ---
POSTGRES_USER=storyforge
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-24
POSTGRES_DB=storyforge

# --- Neo4j ---
# Format: <user>/<password>. The user must be "neo4j" for the Community image.
NEO4J_AUTH=neo4j/replace-me-with-openssl-rand-hex-24
